{
  "expo": {
    "name": "FitDadForge",
    "slug": "fitdadforge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0908"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0a0908"
      }
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro",
      "backgroundColor": "#0a0908",
      "themeColor": "#d97706",
      "config": {
        "pwa": {
          "icon": "./assets/logo.png"
        }
      }
    }
  }
}